# =============================================================================
# Super Schema — environment variables
# Copy to `.env` (dev) or `.env.production` and fill in real values.
# Never commit a populated copy of this file.
# =============================================================================

# --- REQUIRED ----------------------------------------------------------------

# Postgres connection string. Prisma's pg adapter speaks plain libpq.
DATABASE_URL="postgresql://user:password@localhost:5432/super_schema?schema=public"

# 32+ random bytes used to sign JWT session tokens AND to derive the symmetric
# key that encrypts user-stored API keys (BYOK). Rotating this invalidates
# every session and every saved key.
#   Generate:  make auth-secret
AUTH_SECRET=""

# Public origin where the app is served. NextAuth uses it to build OAuth
# callback URLs. Set this in production.
#   Example: https://schema.example.com
NEXTAUTH_URL="http://localhost:3000"

# Used by SEO helpers to build absolute URLs for sitemap, canonical, and
# Open Graph metadata. Falls back to NEXTAUTH_URL when unset. Strip the
# trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- LANDING PAGE ------------------------------------------------------------

# Where to send users after a successful sign-in / sign-up. Must start with /.
# Default: /projects
NEXT_PUBLIC_DEFAULT_DASHBOARD="/projects"

# --- OAUTH PROVIDERS (optional) ----------------------------------------------
# A provider lights up only when both ID and SECRET are set. Wire its callback
# URL in the provider's console exactly as shown.

# Google — https://console.cloud.google.com/apis/credentials
#   Callback: ${NEXTAUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub — https://github.com/settings/developers
#   Callback: ${NEXTAUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Microsoft Entra ID — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
#   Callback: ${NEXTAUTH_URL}/api/auth/callback/microsoft-entra-id
#   Tenant: "common" (multi-tenant), "consumers", "organizations", or a tenant GUID.
AUTH_MICROSOFT_ID=""
AUTH_MICROSOFT_SECRET=""
AUTH_MICROSOFT_TENANT="common"

# --- AI ----------------------------------------------------------------------
# AI keys are per-user (BYOK). Users add their own provider + key in Settings.
# No server-wide AI key is needed.

# --- BUILD / RUNTIME ---------------------------------------------------------

# Node environment. Next.js infers this; explicit override only if needed.
# NODE_ENV=production

# Set to "1" to enable Next's standalone output (used by the Dockerfile).
# NEXT_OUTPUT_STANDALONE=1
